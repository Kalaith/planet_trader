{
    "name": "webhatchery/planet_trader-backend",
    "description": "PHP backend for Planet Trader",
    "license": "proprietary",
    "type": "project",    
    "require": {
        "php": "^8.1",
        "illuminate/database": "^10.0",
        "illuminate/events": "^10.0",
        "vlucas/phpdotenv": "^5.5",
        "monolog/monolog": "^3.4",
        "respect/validation": "^2.2",
        "firebase/php-jwt": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5.63",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }    },
    "scripts": {
        "start": [
            "@putenv COMPOSER_PROCESS_TIMEOUT=0",
            "php -S localhost:3001 -t public/"
        ],
        "test": "phpunit --do-not-fail-on-empty-test-suite tests",
        "cs-check": "phpcs --standard=PSR12 --warning-severity=0 src/ tests/",
        "cs-fix": "phpcbf --standard=PSR12 src/ tests/"
    },
    "config": {
        "process-timeout": 0
    }
}
